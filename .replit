modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["mongodb"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

# Production server (next start) — avoids Replit filesystem + HMR rebuild loops that crash Next dev.
[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["bash", "start-prod.sh"]
build = ["npm", "run", "build"]
publicDir = "public"

[userenv]

[userenv.shared]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY = "pk_test_51Rvq4r2Ouu0wp8JqMcQrvvkDgUlLigRMJuOkpxPOzLClJqtf13H9SmsRxEPhov6wmlZVZ7FoKgPm9oaZrxC3S5Bk00TYtmRNJ0"

[userenv.development]
NEXTAUTH_URL = "https://b8f4d0d5-4c4d-42b1-bbad-5d5c166f5c2f-00-3ue2u6qtda2ml.spock.replit.dev"

[userenv.production]
CUSTOM_DOMAIN = "https://pm.smarts.fi"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
