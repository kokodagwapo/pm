    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "setup:local": "docker compose -f docker-compose.dev.yml up -d --wait && node -r dotenv/config src/scripts/auto-seed.mjs dotenv_config_path=.env.local",
