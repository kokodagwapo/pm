    "seed:35": "tsx src/scripts/seed-35-properties.ts",
    "export:data": "tsx src/scripts/export-data.ts",
    "import:data": "tsx src/scripts/import-data.ts",
    "seed:all": "npm run seed:demo && npm run seed:ai-assistants && npm run seed:35 && npm run seed:pricing && npm run seed:faq && npm run seed:owners"
  },
