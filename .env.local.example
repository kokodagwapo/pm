# =============================================================================
# SmartStartPM — Local Development Environment Variables
# =============================================================================
# Copy this file to .env.local — works immediately with zero changes:
#   cp .env.local.example .env.local
#
# Then run:
#   npm run setup:local    # starts MongoDB in Docker + seeds demo data
#   npm run dev:local       # starts dev server at http://localhost:3000
#
# Demo login (sign-in page has quick-login buttons):
#   Admin:   hi@smartstart.us         / SmartStart2025
#   Manager: manager@smartstart.us    / SmartStart2025
#   Owner:   owner@smartstart.us      / SmartStart2025
#   Tenant:  tenant@smartstart.us     / SmartStart2025
# =============================================================================

# --- Database (Docker) -------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/SmartStartPM

# --- NextAuth -----------------------------------------------------------------
# MUST match the origin you open in the browser (scheme + host + port) or sign-in fails with MissingCSRF.
# For port 3000: NEXTAUTH_URL=http://localhost:3000
# For port 3001 (Docker / dev:3001): NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=smartstartpm-local-dev-secret-32chars!!
AUTH_TRUST_HOST=true
AUTH_SECRET=smartstartpm-local-dev-secret-32chars!!

# --- OAuth (optional — app works without these via credentials login) ---------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Stripe (optional — payment features disabled without these) --------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Cloudflare R2 Storage (optional — image uploads disabled without these) --
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
# NEXT_PUBLIC_R2_PUBLIC_URL=

# --- OpenAI (optional — AI assistant features disabled without this) ----------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Email / SMTP (optional — email notifications disabled without these) -----
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@smartstartpm.com
# ENABLE_EMAIL_NOTIFICATIONS=false

# --- App Config ---------------------------------------------------------------
# Same port as NEXTAUTH_URL when using credentials / CSRF.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=SmartStartPM
