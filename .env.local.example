# =============================================================================
# SmartStartPM — Local Development Environment Variables
# =============================================================================
# Copy this file to .env.local — works immediately with zero changes:
#   cp .env.local.example .env.local
#
# Then run:
#   npm run docker:mongo   # MongoDB only (Docker), waits until healthy
#   npm run setup:local    # MongoDB + seed demo data (first-time)
#   npm run dev:with-mongo # MongoDB then Next on :3000 (recommended)
#   npm run dev:local      # Next only — needs Mongo already running
#
# If port 3000 is busy: npm run dev:3020 and set NEXTAUTH_URL / AUTH_URL / NEXT_PUBLIC_APP_URL to http://localhost:3020
#
# Internal Server Error on / in dev — usually fixed by:
#   npm run docker:mongo
#   npm run dev:clean:with-mongo
# Or use production mode: npm run build && npm run start:local
# Confirm nothing else owns 3000: lsof -iTCP:3000 -sTCP:LISTEN
#
# Demo login (sign-in page has quick-login buttons):
#   Admin:   hi@smartstart.us         / SmartStart2025
#   Manager: manager@smartstart.us    / SmartStart2025
#   Owner:   owner@smartstart.us      / SmartStart2025
#   Tenant:  tenant@smartstart.us     / SmartStart2025
# =============================================================================
#
# --- Replit (hosted) ----------------------------------------------------------
# In the Replit Secrets panel, set at minimum:
#   AUTH_SECRET=...              # openssl rand -base64 32
#   NEXTAUTH_SECRET=...          # can match AUTH_SECRET
#   MONGODB_URI=...              # MongoDB Atlas connection string (recommended), or omit for local mongod
#   NEXT_PUBLIC_APP_URL=https://<your-repl>.replit.app   # or custom domain
# Optional: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY, STRIPE_SECRET_KEY, R2_*, OPENAI_API_KEY,
#   UNIT_SECRETS_ENCRYPTION_KEY (unit WiFi/door codes), NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
# Run uses bash start.sh → next build if needed → next start on port 5000.
# Set REPLIT_DEV_SERVER=1 in Secrets only if you need `next dev` + HMR (less stable).
#
# =============================================================================

# --- Database (Docker) -------------------------------------------------------
# Listings and all app data live in MongoDB (database name in the URI path, e.g. SmartStartPM).
# Collection: `properties` (Mongoose model Property). VMS imports set importSource=vms-florida.com.
MONGODB_URI=mongodb://localhost:27017/SmartStartPM

# Allow `npm run seed:demo` / demo quick-login in non-production (required once before migrate:vms).
ENABLE_DEMO_AUTH=true

# --- NextAuth -----------------------------------------------------------------
# Leave NEXTAUTH_URL and AUTH_URL UNSET for local dev if you use either http://127.0.0.1:3000
# or http://localhost:3000 — Auth.js will use the Host header and both work.
# If you set them, they MUST match the exact origin in the address bar (including 127.0.0.1 vs localhost).
# Custom port / tunnel: uncomment and set, e.g. NEXTAUTH_URL=http://localhost:3020
# NEXTAUTH_URL=http://localhost:3000
# AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=smartstartpm-local-dev-secret-32chars!!
AUTH_TRUST_HOST=true
AUTH_SECRET=smartstartpm-local-dev-secret-32chars!!

# --- OAuth (optional — app works without these via credentials login) ---------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Stripe (optional — payment features disabled without these) --------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Cloudflare R2 Storage (optional — image uploads disabled without these) --
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
# NEXT_PUBLIC_R2_PUBLIC_URL=

# --- OpenAI (optional — AI assistant features disabled without this) ----------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Email / SMTP (optional — email notifications disabled without these) -----
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@smartstartpm.com
# ENABLE_EMAIL_NOTIFICATIONS=false

# --- App Config ---------------------------------------------------------------
# Same port as NEXTAUTH_URL when using credentials / CSRF.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=SmartStartPM

# --- Unit access secrets (WiFi / door codes) — AES-256-GCM at rest ------------
# Generate a 32-byte key: openssl rand -hex 32
# Required to save WiFi password or door passcode on a unit (dashboard API).
# UNIT_SECRETS_ENCRYPTION_KEY=

# --- Google Maps (optional — maps on property pages when set) -----------------
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_GEOCODE_KEY=
